---
import Gallery from "../components/Gallery.astro";

import "@/styles/colors.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="A website to showcase some cool photos I've taken."
    />
    <title>Aperturic Focus</title>
  </head>
  <body>
    <aside>
      <h1>Aperturic Focus</h1>
      <p>A website to showcase some cool photos I've taken.</p>
      <section>
        <a href="#2019">2019</a>
        <a href="#2021">2021</a>
        <a href="#2022">2022</a>
        <a href="#2023">2023</a>
      </section>
    </aside>
    <main> 
      <Gallery />
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: dark light;
    font-family: system-ui;
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--background);
    color: var(--text)
    margin: 0;
    display: grid;
    grid-template-columns: auto 1fr;
    padding: 1rem;
    gap: 1rem;

    @media (max-width: 768px) {
      grid-template-columns: unset;
      grid-template-rows: auto 1fr;
    }
  }

  p {
    font-size: 1.5rem;
  }

  h1 {
    font-size: min(3rem, 10vmin);
    color: var(--accent);
    margin-bottom: 0;
  }

  main {
    width: min(64rem, 88dvw);
    margin: auto;
  }

  section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  a {
    color: var(--text);
    font-weight: bold;
    text-decoration: none;
    width: fit-content;
    padding: 0.5rem;
    border-radius: 0.5rem;
    transition: all 0.25s;

    &:hover {
      background-color: var(--primary);
      color: var(--on-primary);
    }
  }

  aside {
    position: sticky;
  }
</style>
