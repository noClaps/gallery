#!/bin/bash

# Upgrade bun before starting build
bun upgrade

# Clear dist/ and tmp/ if they exist
rm -rf ./dist/ ./tmp/

# Copy public files
mkdir -p ./dist/
cp ./public/* ./dist/

# Build CSS
bun ./build-tools/css.ts

# Build images
mkdir -p ./tmp/
bun ./build-tools/images.ts

# Build HTML
bun ./build-tools/html.ts
rm -rf ./tmp/
